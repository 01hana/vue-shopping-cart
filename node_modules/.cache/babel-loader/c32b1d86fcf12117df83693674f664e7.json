{"ast":null,"code":"export default {\n  name: 'SideCart',\n  props: ['cartShow', 'cart', 'total'],\n  emits: ['cartClose'],\n  computed: {\n    cartTotal() {\n      if (!Object.keys(this.cart).length) {\n        return 0;\n      } else {\n        return this.total * 590;\n      }\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAsCA,eAAe;EACbA,IAAI,EAAE,UADO;EAEbC,KAAK,EAAE,CAAC,UAAD,EAAa,MAAb,EAAqB,OAArB,CAFM;EAGbC,KAAK,EAAE,CAAC,WAAD,CAHM;EAIbC,QAAQ,EAAE;IACRC,SAAQ,GAAK;MACX,IAAI,CAACC,MAAM,CAACC,IAAP,CAAY,KAAKC,IAAjB,EAAuBC,MAA5B,EAAoC;QAClC,OAAO,CAAP;MACF,CAFA,MAEO;QACL,OAAO,KAAKC,KAAL,GAAa,GAApB;MACF;IACF;;EAPQ;AAJG,CAAf","names":["name","props","emits","computed","cartTotal","Object","keys","cart","length","total"],"sourceRoot":"","sources":["/Users/lineva/Desktop/vueProject/shopping-cart/src/components/SideCart.vue"],"sourcesContent":["<template>\n  <transition name=\"cart\">\n    <aside id=\"cart-container\">\n      <div\n        id=\"cart-head\"\n        class=\"d-flex align-items-center justify-content-between mb-3\">\n        <h5>購物車</h5>\n        <span class=\"cart-closebtn\" @click=\"$emit('cartClose')\">&times;</span>\n      </div>\n      <div class=\"cart-item d-flex align-items-center justify-content-between mb-3\" v-for=\"i in cart\" :key=\"i.id\">\n            <div class=\"d-flex align-items-center\">\n                <img :src=\"i.color\" alt=\"\" />\n                <div class=\"table-container m-3\">\n                <table>\n                    <h6 class=\"m-0\">無領打褶澎袖上衣</h6>\n                    <tr class=\"cart-item-info d-flex justify-content-start\">\n                    <th>Size：</th>\n                    <td>{{ i.size }}</td>\n                    </tr>\n                    <tr class=\"cart-item-info d-flex justify-content-start\">\n                    <th>QTY：</th>\n                    <td>{{ i.qty }}</td>\n                    </tr>\n                </table>\n                </div>\n            </div>\n            <span class=\"item-delete\">&times;</span>\n        </div>\n        <p class=\"text-center\" v-if=\"!Object.keys(cart).length\">購物車目前沒有商品</p>\n        <div class=\"d-flex justify-content-between\">\n            <span>Total：${{ cartTotal }}</span>\n            <button type=\"button\" class=\"checkout-btn\">Checkout</button>\n        </div>\n    </aside>\n  </transition>\n</template>\n\n<script>\nexport default {\n  name: 'SideCart',\n  props: ['cartShow', 'cart', 'total'],\n  emits: ['cartClose'],\n  computed: {\n    cartTotal () {\n      if (!Object.keys(this.cart).length) {\n        return 0\n      } else {\n        return this.total * 590\n      }\n    }\n  }\n}\n</script>\n\n<style>\n#cart-container {\n  height: 100%;\n  width: 400px;\n  position: fixed;\n  z-index: 1;\n  top: 0;\n  right: 0;\n  background-color: #f1e2ca;\n  overflow-x: hidden;\n  transition: 0.5s ease;\n  padding: 15px 15px 0;\n}\n\n.cart-closebtn {\n  font-size: 36px;\n  padding: 0;\n  cursor: pointer;\n}\n\n.cart-item-info {\n  font-size: 14px;\n}\n\n.cart-item img {\n  width: 60px;\n  height: 70px;\n}\n\n.item-delete {\n  font-size: 28px;\n  cursor: pointer;\n}\n\n.checkout-btn{\n    width: 8vw;\n    font-size: 14px;\n    background-color: white;\n    border: 1px solid white;\n    border-radius: 5px;\n    box-shadow: rgb(221, 216, 216) 0px 3px 3px;\n}\n\n.cart-enter-from,\n.cart-leave-to {\n  transform: translateX(100%);\n}\n\n.cart-enter-to,\n.cart-leave-from {\n  transform: translateX(0%);\n}\n\n.cart-enter-active,\n.cart-leave-active {\n  transition: 0.5s ease;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}