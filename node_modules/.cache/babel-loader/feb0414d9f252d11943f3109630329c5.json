{"ast":null,"code":"export default {\n  name: 'SideCart',\n  props: ['cartShow', 'cart', 'total', 'remove', 'inventory'],\n  emits: ['cartClose'],\n  computed: {\n    cartTotalQty() {\n      if (!Object.keys(this.cart).length) {\n        return 0;\n      } else {\n        return this.total;\n      }\n    }\n\n  },\n  methods: {\n    calCartTotal() {\n      const initialValue = 0;\n      const totalPrice = this.cart.forEach(p => {\n        return p.price;\n      }).reduce((prev, curr) => {\n        return prev + curr;\n      }, initialValue);\n      return totalPrice;\n    }\n\n  }\n};","map":{"version":3,"mappings":"AA6CA,eAAe;EACbA,IAAI,EAAE,UADO;EAEbC,KAAK,EAAE,CAAC,UAAD,EAAa,MAAb,EAAqB,OAArB,EAA8B,QAA9B,EAAwC,WAAxC,CAFM;EAGbC,KAAK,EAAE,CAAC,WAAD,CAHM;EAIbC,QAAQ,EAAE;IACRC,YAAW,GAAK;MACd,IAAI,CAACC,MAAM,CAACC,IAAP,CAAY,KAAKC,IAAjB,EAAuBC,MAA5B,EAAoC;QAClC,OAAO,CAAP;MACF,CAFA,MAEO;QACL,OAAO,KAAKC,KAAZ;MACF;IACF;;EAPQ,CAJG;EAabC,OAAO,EAAE;IACPC,YAAW,GAAK;MACd,MAAMC,YAAW,GAAI,CAArB;MACA,MAAMC,UAAS,GAAI,KAAKN,IAAL,CAAUO,OAAV,CAAkBC,KAAK;QACxC,OAAOA,CAAC,CAACC,KAAT;MACD,CAFkB,EAEhBC,MAFgB,CAET,CAACC,IAAD,EAAOC,IAAP,KAAgB;QACxB,OAAOD,IAAG,GAAIC,IAAd;MACD,CAJkB,EAIhBP,YAJgB,CAAnB;MAKA,OAAOC,UAAP;IACF;;EATO;AAbI,CAAf","names":["name","props","emits","computed","cartTotalQty","Object","keys","cart","length","total","methods","calCartTotal","initialValue","totalPrice","forEach","p","price","reduce","prev","curr"],"sourceRoot":"","sources":["/Users/lineva/Desktop/vueProject/shopping-cart/src/components/SideCart.vue"],"sourcesContent":["<template>\n  <transition name=\"cart\">\n    <aside id=\"cart-container\">\n      <div\n        id=\"cart-head\"\n        class=\"d-flex align-items-center justify-content-between mb-3\">\n        <h5>購物車</h5>\n        <span class=\"cart-closebtn\" @click=\"$emit('cartClose')\">&times;</span>\n      </div>\n      <div class=\"cart-item d-flex align-items-center justify-content-between mb-3\" v-for=\"i in cart\" :key=\"i.id\">\n            <div class=\"d-flex align-items-center\">\n                <div class=\"table-container m-3\">\n                <table>\n                    <h6 class=\"m-0\">{{ i.name }}</h6>\n                    <tr class=\"cart-item-info d-flex justify-content-start\">\n                      <th>Color：</th>\n                      <td>{{ i.color }}</td>\n                    </tr>\n                    <tr class=\"cart-item-info d-flex justify-content-start\">\n                      <th>Size：</th>\n                      <td>{{ i.size }}</td>\n                    </tr>\n                    <tr class=\"cart-item-info d-flex justify-content-start\">\n                      <th>QTY：</th>\n                      <td>{{ i.qty }}</td>\n                    </tr>\n                    <tr class=\"cart-item-info d-flex justify-content-start\">\n                      <th>Price：</th>\n                      <td>{{ i.price }}</td>\n                    </tr>\n                </table>\n                </div>\n            </div>\n            <span @click=\"remove(i.id)\" class=\"item-delete\">&times;</span>\n        </div>\n        <p class=\"text-center\" v-if=\"!Object.keys(cart).length\">購物車目前沒有商品</p>\n        <div class=\"d-flex justify-content-between\">\n            <span>Total：${{ calCartTotal }}</span>\n            <button type=\"button\" class=\"checkout-btn\">Checkout</button>\n        </div>\n    </aside>\n  </transition>\n</template>\n\n<script>\nexport default {\n  name: 'SideCart',\n  props: ['cartShow', 'cart', 'total', 'remove', 'inventory'],\n  emits: ['cartClose'],\n  computed: {\n    cartTotalQty () {\n      if (!Object.keys(this.cart).length) {\n        return 0\n      } else {\n        return this.total\n      }\n    }\n  },\n  methods: {\n    calCartTotal () {\n      const initialValue = 0\n      const totalPrice = this.cart.forEach(p => {\n        return p.price\n      }).reduce((prev, curr) => {\n        return prev + curr\n      }, initialValue)\n      return totalPrice\n    }\n  }\n}\n</script>\n\n<style>\n#cart-container {\n  height: 100%;\n  width: 400px;\n  position: fixed;\n  z-index: 3;\n  top: 0;\n  right: 0;\n  background-color: #f1e2ca;\n  overflow-x: hidden;\n  transition: 0.5s ease;\n  padding: 15px 15px 0;\n}\n\n.cart-closebtn {\n  font-size: 36px;\n  padding: 0;\n  cursor: pointer;\n}\n\n.cart-item-info {\n  font-size: 14px;\n}\n\n.cart-item img {\n  width: 60px;\n  height: 70px;\n}\n\n.item-delete {\n  font-size: 28px;\n  cursor: pointer;\n}\n\n.checkout-btn{\n    width: 8vw;\n    font-size: 14px;\n    background-color: white;\n    border: 1px solid white;\n    border-radius: 5px;\n    box-shadow: rgb(221, 216, 216) 0px 3px 3px;\n}\n\n.cart-enter-from,\n.cart-leave-to {\n  transform: translateX(100%);\n}\n\n.cart-enter-to,\n.cart-leave-from {\n  transform: translateX(0%);\n}\n\n.cart-enter-active,\n.cart-leave-active {\n  transition: 0.5s ease;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}